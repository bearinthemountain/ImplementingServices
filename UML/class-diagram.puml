@startuml class-diagram
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam class {
  BackgroundColor White
  BorderColor #444
  ArrowColor #444
}
skinparam stereotype {
  CBackgroundColor #E8F4FD
  CBorderColor #2980B9
}

' ══════════════════════════════════════════
'  BUSINESS OBJECTS
' ══════════════════════════════════════════
package "ch.hevs.businessobject" #FAFAFA {

  class User {
    - id : long
    - lastname : String
    - firstname : String
    - balance : BigDecimal
    --
    + getBalance() : BigDecimal
    + setBalance(BigDecimal) : void
    + getId() : long
    + getLastname() : String
    + getFirstname() : String
  }

  abstract class Media {
    - id : Long
    - title : String
    - director : String
    - price : BigDecimal
    --
    + {abstract} getRentalDurationInDays() : int
    + getPrice() : BigDecimal
    + getTitle() : String
    + getDirector() : String
  }

  class Movie {
    - duration : int
    --
    + getRentalDurationInDays() : int
    + getDuration() : int
  }
  note right of Movie : rentalDuration = 1 day

  class Serie {
    - seasons : int
    - episodes : int
    --
    + getRentalDurationInDays() : int
    + getSeasons() : int
    + getEpisodes() : int
  }
  note right of Serie : rentalDuration = 30 days

  class Category {
    - id : Long
    - name : String
    --
    + getName() : String
  }

  class Rental {
    - id : Long
    - rentalStart : LocalDateTime
    - rentalEnd : LocalDateTime
    - appliedPrice : BigDecimal
    --
    + isExpired() : boolean
    + getAppliedPrice() : BigDecimal
    + getRentalStart() : LocalDateTime
    + getRentalEnd() : LocalDateTime
  }

  Media <|-- Movie
  Media <|-- Serie
  Media "0..*" -- "0..1" Category : category
  Rental "0..*" -- "1" User    : user
  Rental "0..*" -- "1" Media   : media
}

' ══════════════════════════════════════════
'  EXCEPTION
' ══════════════════════════════════════════
package "ch.hevs.exception" #FAFAFA {

  class RentalException {
    - reason : Reason
    --
    + getReason() : Reason
    + getMessage() : String
  }

  enum Reason {
    USER_NOT_FOUND
    MEDIA_NOT_FOUND
    ALREADY_RENTED
    INSUFFICIENT_FUNDS
  }

  RentalException +-- Reason
}

' ══════════════════════════════════════════
'  SERVICE LAYER
' ══════════════════════════════════════════
package "ch.hevs.service" #FAFAFA {

  class MediaService <<@ApplicationScoped>> {
    - em : EntityManager
    --
    + getAllMedia() : List<Media>
    + saveMedia(Media) : void
    + refreshMedia() : List<Media>
    + getAllCategories() : List<Category>
    + getCategoryById(Long) : Category
  }

  class RentalService <<@RequestScoped>> {
    - em : EntityManager
    --
    + rentMedia(Long, Long) : void
    + getViewerById(Long) : User
    + getActiveRentals(Long) : List<Rental>
  }

  class UserService <<@RequestScoped>> {
    - em : EntityManager
    --
    + getAllViewers() : List<User>
    + getUserByPrincipal(Principal) : User
    + getUserByLastname(String) : User
  }

  RentalService ..> RentalException : <<throws>>
}

' ══════════════════════════════════════════
'  PRESENTATION LAYER
' ══════════════════════════════════════════
package "ch.hevs.presentation" #FAFAFA {

  class AdminBean <<@SessionScoped>> {
    - mediaType : String
    - title : String
    - director : String
    - price : BigDecimal
    - categoryId : Long
    - duration : int
    - seasons : int
    - episodes : int
    --
    + addMedia() : String
    + getCategories() : List<Category>
  }

  class RentalBean <<@SessionScoped>> {
    - selectedMediaId : Long
    - transactionResult : String
    --
    + getLoggedInUser() : User
    + performRental() : String
    + getMyActiveRentals() : List<Rental>
    + getMedias() : List<Media>
  }

  class MediaBean <<@SessionScoped>> {
    --
    + getMedias() : List<Media>
  }

  class UserBean <<@SessionScoped>> {
    - users : List<User>
    --
    + getAllViewers() : List<User>
  }

  AdminBean  --> MediaService  : @Inject
  RentalBean --> RentalService : @Inject
  RentalBean --> MediaService  : @Inject
  RentalBean --> UserService   : @Inject
  MediaBean  --> MediaService  : @Inject
  UserBean   --> UserService   : @Inject
}

@enduml
